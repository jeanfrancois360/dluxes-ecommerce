# Application
NODE_ENV=development
PORT=3001
API_PREFIX=api/v1

# Database
DATABASE_URL="postgresql://luxury:luxury@localhost:5432/nextpik_ecommerce?schema=public"

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this
JWT_EXPIRES_IN=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Meilisearch
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=masterKey

# CORS
CORS_ORIGIN=http://localhost:3000

# Rate Limiting
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# EasyPost Configuration
EASYPOST_API_KEY=EASYPOST_TEST_xxxxx
EASYPOST_TEST_MODE=true
EASYPOST_WEBHOOK_SECRET=

# ===== Phase C — Affiliate (Awin) =====
# Awin Publisher API credentials (https://ui.awin.com/publisher-dashboard/api-credentials)
AWIN_PUBLISHER_ID=
AWIN_API_TOKEN=

# ===== Phase C — Content translation =====
# DeepL API key for machine translation of blog/affiliate content (https://www.deepl.com/pro-api)
DEEPL_API_KEY=

# ===== Phase C — Newsletter =====
# Resend audience ID for newsletter subscribers (https://resend.com/audiences)
RESEND_AUDIENCE_ID=
